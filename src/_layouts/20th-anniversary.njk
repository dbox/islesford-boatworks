---
layout: base.njk
title: The 20th Anniversary of Islesford Boatworks
bodyClass: twenty-anniversary
changeFreq: yearly
---
<article class="anniversary-page">
  
  {# 1. HERO SECTION #}
  <header class="hero">

    <div class="container">
      <h1>{{ hero.title }}</h1>

    </div>
    <img src="{{ hero.image }}" alt="{{ hero.title }}" class="hero-bg">  
    <div class="badge"><img src="{{ hero.badge.image }}" alt="{{ hero.badge.title }}" >  </div> 
    <div class="intro-box">
  {# Use the | md | safe filter to allow markdown stars in your introBox #}
  {{ hero.introBox | md | safe }}
</div>
  </header>

{# 2. EVENTS SECTION #}
  <section class="events-section">
    <div class="container">
      <header class="section-header">
        <h2>{{ events.heading }}</h2>
        <h3>{{ events.subheading }}</h3>
        <p>{{ events.body }}</p>
      </header>

      <div class="events-grid">
        {% for card in events.cards %}
          <div class="event-card">
            
            {# Image Container #}
            <div class="card-thumb">
              <div class="event-date-badge">
                <div class="date-wrap">
                  {% if card.date %}
                    <span class="month">{{ card.date | htmlDateString("MMM") }}</span>
                    <span class="day">{{ card.date | htmlDateString("d") }}</span>
                  {% else %}
                    <span class="month">Date</span>
                    <span class="day">TBD</span>
                  {% endif %}
                </div>
              </div>                 
              <img src="{{ card.image }}" alt="{{ card.image_alt }}">
           
            </div>

            <div class="card-content">
              {# SPLIT DATE BADGE #}

              
              <h4>{{ card.title }}</h4>
              
              {# The excerpt supports Markdown now too #}
              <p class="excerpt">
                {{ card.excerpt | md | safe }}
              </p>
              
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# 3. MAIN CONTENT (The History section from below your dashes) #}
  <section class="history-content container">
    <hr>
    <div class="history-layout">
      <div class="history-main">
        {{ content | safe }}
      </div>

      {% if sidebar %}
        <aside class="history-sidebar" aria-labelledby="legacy-fund-heading">
          {% set progressPercent = 0 %}
          {% if sidebar.current_amount and sidebar.goal_amount %}
            {% set progressPercent = ((sidebar.current_amount / sidebar.goal_amount) * 100) %}
          {% endif %}
          <div class="sidebar-card">
            <p class="sidebar-kicker">{{ sidebar.heading }}</p>

            {% if sidebar.current_amount and sidebar.goal_amount %}
              <!-- <h3 id="legacy-fund-heading" class="sidebar-amount">${{ sidebar.current_amount | intComma }}</h3> -->
              <div class="sidebar-meter" aria-hidden="true">
                <span class="sidebar-meter-fill" style="width: {{ progressPercent | round(1) }}%;"></span>
              </div>
              <!-- <p class="sidebar-goal">Our goal is ${{ sidebar.goal_amount | intComma }}.</p> -->
            {% endif %}

            {% if sidebar.content %}
              <div class="sidebar-copy">
                {{ sidebar.content | md | safe }}
              </div>
            {% endif %}

            {% if sidebar.buttonHref and sidebar.buttonText %}
              <p class="sidebar-action">
                <a href="{{ sidebar.buttonHref }}" class="sidebar-button">{{ sidebar.buttonText }}</a>
              </p>
            {% endif %}
          </div>
        </aside>
      {% endif %}
    </div>
  </section>

</article>
